# Copy to .env and fill in real values. Never commit .env.
NODE_ENV=development
APP_URL=http://localhost:3000

# Database - Neon connection string.
# Use Neon pooled URL for Vercel runtime. Use sslmode=verify-full to avoid
# future pg SSL-mode behavior changes.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=verify-full"

# Auth.js v5 — generate with: openssl rand -base64 32
AUTH_SECRET=
# Optional in dev. Set to canonical app URL in production.
# AUTH_URL=https://your-domain.com

# Phase 2 — Twilio (leave blank until Phase 6 lands)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_WEBHOOK_AUTH_TOKEN=

# Phase 3 — Stripe (leave blank until Phase 7 lands)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Email - Resend (recommended for app-sent transactional email).
# When unset, emails are simulated and logged.
EMAIL_PROVIDER=resend
RESEND_API_KEY=
RESEND_FROM_EMAIL="TLM Portal <noreply@yourdomain.com>"

# Optional alternative: Microsoft 365 / Outlook SMTP.
# For GoDaddy Microsoft 365, SMTP is usually smtp.office365.com:587 STARTTLS.
# Use only if SMTP AUTH is enabled for the mailbox.
# EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# AI — Anthropic Claude (used by /admin/customers/[id]/ad-recommendations)
ANTHROPIC_API_KEY=

# Vercel Cron auth - generate with: openssl rand -hex 32
# Vercel sends Authorization: Bearer <CRON_SECRET> on cron invocations.
# Required in production. Local dev can omit it.
CRON_SECRET=
