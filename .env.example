# Copy to .env and fill in real values. Never commit .env.
NODE_ENV=development
APP_URL=http://localhost:3000

# Database — Neon connection string (use the pooled URL for runtime)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Auth.js v5 — generate with: openssl rand -base64 32
AUTH_SECRET=
# Optional in dev. Set to canonical app URL in production.
# AUTH_URL=https://your-domain.com

# Phase 2 — Twilio (leave blank until Phase 6 lands)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_WEBHOOK_AUTH_TOKEN=

# Phase 3 — Stripe (leave blank until Phase 7 lands)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
